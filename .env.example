# Petalia Backend - Environment Configuration
# Copiez ce fichier vers .env.development ou .env.production

# ─── PostgreSQL + PostGIS ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=petalia
DB_PASSWORD=secret
DB_NAME=petalia

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=UUYYS56FSGVGCFCFTVFCFCFTYT6TGTVTGV
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=7HUYDVTDTVGDVGVGDVGVHGDBVGVGDVGD
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ─── Orange SMS (OTP) ────────────────────────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER_ADDRESS=tel:+221XXXXXXXXX

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Cloudinary (upload photos) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Sentinel Hub (NDVI) ──────────────────────────────────────────────────
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ─── OpenWeatherMap ───────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ─── Interop Webhooks ─────────────────────────────────────────────────────
# Secret partagé avec le partenaire assurance pour valider HMAC-SHA256
INSURANCE_WEBHOOK_SECRET=
# Secret partagé avec les banques partenaires pour signer les rapports
BANK_API_SECRET=
