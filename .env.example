# Petalia Backend - Environment Configuration
# Copiez ce fichier vers .env.development ou .env.production
#
# Naming convention:
#   - DB_*               → read by the NestJS app (TypeORM datasource)
#   - POSTGRES_*         → read by the postgres container in docker-compose
#   - REDIS_PASSWORD     → shared between app and redis container
#   - MINIO_ROOT_*       → read by the minio container
#   - DOCKERHUB_USERNAME → read by docker compose at YAML parse time

# ─── PostgreSQL + PostGIS ─────────────────────────────────────────────────
# App-side (TypeORM)
DB_HOST=localhost
DB_PORT=5432
DB_USER=petalia
DB_PASSWORD=secret
DB_NAME=petalia
# Container-side (must match app values when both are on the same compose stack)
POSTGRES_USER=petalia
POSTGRES_PASSWORD=secret
POSTGRES_DB=petalia

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────
JWT_SECRET=UUYYS56FSGVGCFCFTVFCFCFTYT6TGTVTGV
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_SECRET=7HUYDVTDTVGDVGVGDVGVHGDBVGVGDVGD
REFRESH_TOKEN_EXPIRES_IN=30d

# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200

# ─── Orange SMS (OTP) ────────────────────────────────────────────────────
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER_ADDRESS=tel:+221XXXXXXXXX

# ─── Firebase Cloud Messaging ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Cloudinary (upload photos) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Sentinel Hub (NDVI) ──────────────────────────────────────────────────
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ─── OpenWeatherMap ───────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ─── Interop Webhooks ─────────────────────────────────────────────────────
# Secret partagé avec le partenaire assurance pour valider HMAC-SHA256
INSURANCE_WEBHOOK_SECRET=
# Secret partagé avec les banques partenaires pour signer les rapports
BANK_API_SECRET=

# ─── Monitoring & Alerting ────────────────────────────────────────────────
# Bearer token required to scrape /api/metrics outside the private network
METRICS_TOKEN=
# Slack incoming webhook for in-process alerter (queue failures, payment errors)
SLACK_WEBHOOK_URL=
# Suppress repeat alerts with the same key within this window (ms, default 5 min)
SLACK_ALERT_DEDUP_MS=300000

# ─── DockerHub (déploiement EC2) ─────────────────────────────────────────
# Consommé par docker-compose.deploy.yml sur l'EC2 pour pull l'image API.
# Le username doit matcher le compte DockerHub où le CI pousse l'image.
# IMAGE_TAG est injecté par GitHub Actions (sha-<commit>) — fallback `latest`.
# DOCKERHUB_TOKEN reste vide ici en prod (injecté par CI au login uniquement).
DOCKERHUB_USERNAME=
DOCKERHUB_TOKEN=
IMAGE_TAG=latest

# ─── MinIO (object storage) ──────────────────────────────────────────────
# Utilisé pour stocker photos diagnostic, exports SIG volumineux, backups.
# Le mot de passe doit faire >= 8 caractères (exigence MinIO).
MINIO_ROOT_USER=petalia_minio
MINIO_ROOT_PASSWORD=

# ─── App URL publique (lien reset password SMS) ──────────────────────────
APP_PUBLIC_URL=https://app.petalia.farm

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── Anthropic Claude (Diagnostic Vision) ────────────────────────────────
ANTHROPIC_API_KEY=
