{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Requests/sec",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(petalia_http_requests_total[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Error rate (5xx)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(petalia_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(petalia_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 2 }
      }
    },
    {
      "type": "stat",
      "title": "p95 latency",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(petalia_http_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Active queue jobs",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(petalia_queue_jobs_active)", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (route) (rate(petalia_http_requests_total[1m]))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 latency by route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(petalia_http_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Queue depth (waiting)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "petalia_queue_jobs_waiting",
          "refId": "A",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue failures (rate/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (queue) (rate(petalia_queue_jobs_failed_total[5m]))",
          "refId": "A",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "External API latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(petalia_external_api_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Business events (rate/min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by (event, outcome) (rate(petalia_business_events_total[1m]) * 60)",
          "refId": "A",
          "legendFormat": "{{event}} ({{outcome}})"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["petalia"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "",
  "title": "Petalia API — Overview",
  "uid": "petalia-overview",
  "version": 1
}
